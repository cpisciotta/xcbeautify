# SwiftFormat Configuration

--minversion 0.60.1

# Rules

--disable swiftTestingTestCaseNames
--disable unusedArguments

--enable acronyms
--enable blockComments
--enable isEmpty
--enable noExplicitOwnership
--enable noGuardInTests
--enable preferFinalClasses
--enable preferSwiftTesting
--enable singlePropertyPerLine
--enable sortSwitchCases
--enable testSuiteAccessControl
--enable unusedPrivateDeclarations
--enable validateTestCases
--enable wrapEnumCases
--enable wrapMultilineFunctionChains

# Configuration

--emptybraces spaced
--header "//\n// {file}\n//\n// Copyright (c) {year} Charles Pisciotta and other contributors\n// Licensed under MIT License\n//\n// See https://github.com/cpisciotta/xcbeautify/blob/main/LICENSE for license information\n"
--importgrouping testable-last
--ifdef no-indent
--indent 4
--onelineforeach convert
--ranges no-space
--redundanttype inferred
--semicolons never
--trailing-commas collections-only
--wraparguments before-first
--wrapcollections before-first
--wrapparameters before-first
--xcodeindentation enabled
